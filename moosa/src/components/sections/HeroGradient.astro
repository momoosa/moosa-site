---
/**
 * HeroGradient Section Component
 *
 * A centered hero section with an animated gradient glow background.
 * Feels premium and modern — inspired by Linear, Raycast, and Vercel.
 * The large blurred orbs breathe slowly via a CSS float animation, creating
 * depth without distraction. Glow intensity is stronger in dark mode.
 *
 * @example
 * ```astro
 * <HeroGradient
 *   title="Ship faster, look better"
 *   subtitle="Pre-built Astro components for ambitious teams."
 *   badge="New in v2"
 *   primaryCta={{ href: "/sections", label: "Browse Components" }}
 *   secondaryCta={{ href: "https://github.com/holger1411/astrodeck", label: "GitHub" }}
 * />
 * ```
 *
 * @customization
 * - Adjust orb OKLCH chroma/hue values in the inline style blocks to shift the palette
 * - Change --orb-opacity-* custom properties to increase/decrease glow intensity
 * - Modify the float keyframes duration for faster/slower breathing
 * - Remove badge by omitting the badge prop
 */
interface Props {
  title: string;
  subtitle: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  badge?: string;
}

const { title, subtitle, primaryCta, secondaryCta, badge } = Astro.props;
---

<section class="hero-gradient-section min-h-[70vh] flex items-center py-16 md:py-24 relative overflow-hidden">

  <!-- Gradient orb layer — sits behind all content -->
  <div class="absolute inset-0 pointer-events-none z-0" aria-hidden="true">

    <!-- Orb 1: primary warm-indigo blob, offset top-left of center -->
    <div class="orb orb-1"></div>

    <!-- Orb 2: cool violet blob, offset bottom-right of center -->
    <div class="orb orb-2"></div>

    <!-- Orb 3: small bright accent near top-right, adds sparkle -->
    <div class="orb orb-3"></div>

  </div>

  <!-- Main content -->
  <div
    class="container max-w-5xl mx-auto flex flex-col items-center gap-6 text-center relative z-10"
    data-animate="fade"
  >
    {badge && (
      <a
        href="/changelog"
        class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-medium hover:bg-muted transition-colors"
      >
        <span class="bg-foreground text-background px-2 py-0.5 rounded-md font-semibold text-xs">
          New
        </span>
        <span>{badge}</span>
      </a>
    )}

    <h1 class="text-5xl font-bold leading-tight tracking-tight md:text-7xl lg:text-8xl lg:leading-[1.1] max-w-5xl hero-gradient-title">
      {title}
    </h1>

    <p
      class="max-w-[800px] text-xl text-muted-foreground md:text-2xl"
      set:html={subtitle}
    />

    <div class="flex flex-col sm:flex-row gap-4 mt-4">
      {primaryCta && (
        <a
          href={primaryCta.href}
          class="group relative inline-flex items-center justify-center whitespace-nowrap rounded-md text-base font-semibold ring-offset-background transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 hover:scale-105 h-12 px-12 shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 overflow-hidden"
        >
          <!-- Shine effect overlay -->
          <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"></span>
          <!-- Button text -->
          <span class="relative z-10 inline-block transition-transform duration-300 group-hover:translate-x-0.5">
            {primaryCta.label}
          </span>
        </a>
      )}
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-12 px-8"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>

  <!-- Bottom fade divider -->
  <div class="absolute bottom-0 left-0 right-0 h-px hero-gradient-divider" aria-hidden="true"></div>

</section>

<style>
  /* ============================================================
     Gradient orbs — OKLCH values chosen to be visible in both
     light mode (subtle, 15-18%) and dark mode (stronger, 25-30%).
     Hues: 280 (indigo-violet) and 220 (blue) for a Linear feel.
     ============================================================ */

  .orb {
    position: absolute;
    border-radius: 9999px;
    /* Default (light mode) opacity, overridden per-orb below */
    opacity: 0.15;
    will-change: transform;
  }

  /* --- Orb 1: large indigo, slightly left and up from center --- */
  .orb-1 {
    width: 60vw;
    max-width: 700px;
    height: 60vw;
    max-height: 700px;
    top: 50%;
    left: 40%;
    transform: translate(-50%, -55%);
    background: radial-gradient(
      ellipse at center,
      oklch(60% 0.18 280) 0%,
      oklch(55% 0.14 260) 40%,
      transparent 70%
    );
    filter: blur(100px);
    animation: float-1 8s ease-in-out infinite;
    opacity: 0.15;
  }

  /* --- Orb 2: medium blue-violet, lower-right --- */
  .orb-2 {
    width: 50vw;
    max-width: 580px;
    height: 50vw;
    max-height: 580px;
    top: 55%;
    left: 60%;
    transform: translate(-40%, -45%);
    background: radial-gradient(
      ellipse at center,
      oklch(65% 0.16 220) 0%,
      oklch(60% 0.12 240) 40%,
      transparent 70%
    );
    filter: blur(120px);
    animation: float-2 10s ease-in-out infinite;
    opacity: 0.13;
  }

  /* --- Orb 3: small accent, upper-right, adds brightness --- */
  .orb-3 {
    width: 30vw;
    max-width: 360px;
    height: 30vw;
    max-height: 360px;
    top: 20%;
    left: 70%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse at center,
      oklch(75% 0.14 300) 0%,
      transparent 65%
    );
    filter: blur(80px);
    animation: float-3 7s ease-in-out infinite;
    opacity: 0.10;
  }

  /* Dark mode: orbs become noticeably more vivid */
  :global(.dark) .orb-1 { opacity: 0.28; }
  :global(.dark) .orb-2 { opacity: 0.24; }
  :global(.dark) .orb-3 { opacity: 0.20; }

  /* ============================================================
     Float animations — each orb moves on its own timeline so
     they never feel synchronized or mechanical.
     ============================================================ */

  @keyframes float-1 {
    0%   { transform: translate(-50%, -55%) scale(1.00); }
    40%  { transform: translate(-50%, -62%) scale(1.04); }
    70%  { transform: translate(-53%, -58%) scale(1.02); }
    100% { transform: translate(-50%, -55%) scale(1.00); }
  }

  @keyframes float-2 {
    0%   { transform: translate(-40%, -45%) scale(1.00); }
    35%  { transform: translate(-37%, -50%) scale(1.03); }
    65%  { transform: translate(-43%, -42%) scale(1.05); }
    100% { transform: translate(-40%, -45%) scale(1.00); }
  }

  @keyframes float-3 {
    0%   { transform: translate(-50%, -50%) scale(1.00); }
    50%  { transform: translate(-50%, -58%) scale(1.06); }
    100% { transform: translate(-50%, -50%) scale(1.00); }
  }

  /* Respect reduced-motion preference — freeze all orbs */
  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none !important; }
  }

  /* ============================================================
     Title gradient text effect
     Uses foreground on light, fades to slightly lighter on dark.
     Falls back cleanly if bg-clip-text is unsupported.
     ============================================================ */
  .hero-gradient-title {
    background: linear-gradient(
      135deg,
      var(--color-foreground) 0%,
      oklch(from var(--color-foreground) calc(l + 0.08) c h) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    /* Fallback for browsers that don't support bg-clip text */
    color: var(--color-foreground);
  }

  /* In dark mode, add a subtle glow to the title */
  :global(.dark) .hero-gradient-title {
    background: linear-gradient(
      135deg,
      oklch(98% 0 0) 0%,
      oklch(85% 0.03 280) 60%,
      oklch(80% 0.05 260) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: var(--color-foreground);
  }

  /* ============================================================
     Bottom divider — fades from transparent to border to transparent
     ============================================================ */
  .hero-gradient-divider {
    background: linear-gradient(
      to right,
      transparent 0%,
      var(--color-border) 30%,
      var(--color-border) 70%,
      transparent 100%
    );
  }
</style>
