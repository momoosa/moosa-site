---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import LogoCloud from "@/components/sections/LogoCloud.astro";
import Features from "@/components/sections/Features.astro";
import Stats from "@/components/sections/Stats.astro";
import Pricing from "@/components/sections/Pricing.astro";
import Testimonials from "@/components/sections/Testimonials.astro";
import FAQ from "@/components/sections/FAQ.astro";
import CTA from "@/components/sections/CTA.astro";

const features = [
  {
    title: "Real-Time Collaboration",
    description: "Work together seamlessly with your team. Changes sync instantly across all devices and collaborators.",
    icon: "users",
  },
  {
    title: "Enterprise Security",
    description: "SOC 2 Type II certified with end-to-end encryption, SSO, and granular permission controls.",
    icon: "shield",
  },
  {
    title: "Advanced Analytics",
    description: "Gain actionable insights with customizable dashboards, funnel analysis, and exportable reports.",
    icon: "chart",
  },
  {
    title: "99.99% Uptime SLA",
    description: "Built on distributed infrastructure across 12 global regions for rock-solid reliability.",
    icon: "zap",
  },
  {
    title: "Global CDN",
    description: "Serve your users from the edge. Content delivered in under 50ms anywhere on the planet.",
    icon: "globe",
  },
  {
    title: "Data Privacy",
    description: "GDPR and CCPA compliant. Your data stays yours — we never sell or share it with third parties.",
    icon: "lock",
  },
];

const stats = [
  { value: "120K+", label: "Active Users", description: "Teams across 60+ countries" },
  { value: "99.99%", label: "Uptime", description: "Over the last 12 months" },
  { value: "60+", label: "Countries", description: "Global customer footprint" },
  { value: "4.9/5", label: "Average Rating", description: "From 3,200+ verified reviews" },
];

const tiers = [
  {
    name: "Free",
    price: "$0",
    description: "Perfect for individuals and small side projects.",
    features: [
      "Up to 3 projects",
      "5 GB storage",
      "Community support",
      "Basic analytics",
      "Public API access",
    ],
    cta: { href: "/signup", label: "Get Started Free" },
  },
  {
    name: "Pro",
    price: "$29",
    description: "For professionals and growing teams who need more power.",
    features: [
      "Unlimited projects",
      "100 GB storage",
      "Priority email support",
      "Advanced analytics",
      "Custom domains",
      "Team collaboration (5 seats)",
    ],
    cta: { href: "/signup?plan=pro", label: "Start Free Trial" },
    highlighted: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    description: "Tailored solutions for large organizations and compliance-heavy industries.",
    features: [
      "Unlimited everything",
      "Dedicated infrastructure",
      "24/7 phone & Slack support",
      "Custom SLA",
      "SSO & SAML",
      "Audit logs & SIEM",
    ],
    cta: { href: "/contact", label: "Talk to Sales" },
  },
];

const testimonials = [
  {
    quote: "Nebula cut our deployment time by 70%. Our engineering team finally has time to focus on building features rather than fighting infrastructure.",
    author: "Sarah Chen",
    role: "VP of Engineering",
    company: "Meridian Labs",
  },
  {
    quote: "We evaluated six platforms before choosing Nebula. The real-time collaboration alone was worth the switch — our designers and developers are finally in sync.",
    author: "Marcus Obi",
    role: "Product Lead",
    company: "Foresight Studio",
  },
  {
    quote: "The analytics dashboard gives us visibility we never had before. Within a week we identified and fixed a funnel drop-off that was costing us $40K a month.",
    author: "Priya Nair",
    role: "Head of Growth",
    company: "Orbit Commerce",
  },
];

const faqs = [
  {
    question: "How does the 14-day free trial work?",
    answer: "You get full access to all Pro features for 14 days with no credit card required. At the end of the trial, you can choose to subscribe or downgrade to the Free plan. Your data is never deleted.",
  },
  {
    question: "Can I migrate my existing data into Nebula?",
    answer: "Yes. We provide a guided import wizard that supports CSV, JSON, and direct integrations with Notion, Airtable, and Linear. Our onboarding team assists Enterprise customers with custom migrations at no extra cost.",
  },
  {
    question: "Is Nebula GDPR compliant?",
    answer: "Absolutely. Nebula is GDPR, CCPA, and SOC 2 Type II compliant. All data is stored in encrypted form, and you can request a full data export or deletion at any time from your account settings.",
  },
  {
    question: "What happens if I exceed my plan limits?",
    answer: "We'll notify you at 80% and 100% of your limits. Your account won't be suspended — we give you a 30-day grace period to upgrade or adjust usage before any restrictions apply.",
  },
];
---

<BaseLayout
  title="Nebula — Collaborative SaaS Platform"
  description="Nebula is the all-in-one SaaS platform for modern teams. Real-time collaboration, enterprise security, and powerful analytics — all in one place. Start free."
>
  <Hero
    badge="true"
    title="The platform your team will actually love."
    subtitle="<mark>Nebula</mark> brings real-time collaboration, enterprise-grade security, and actionable analytics together in one beautifully simple platform. <mark>14-day free trial</mark>, no credit card required."
    primaryCta={{ href: "/signup", label: "Start for Free" }}
    secondaryCta={{ href: "/demo", label: "Watch Demo" }}
  />

  <LogoCloud title="Trusted by teams at:" />

  <div class="section-muted">
    <Features
      title="Everything your team needs to ship faster"
      subtitle="Nebula handles the infrastructure so you can focus on what matters — building great products."
      features={features}
    />
  </div>

  <div class="section-inverted">
    <Stats
      title="Trusted by teams worldwide"
      subtitle="Numbers that reflect the trust our customers place in us every day."
      stats={stats}
    />
  </div>

  <Pricing
    title="Simple, transparent pricing"
    subtitle="Start free. Scale as you grow. No hidden fees, no surprises."
    tiers={tiers}
  />

  <div class="section-muted">
    <Testimonials
      title="Loved by engineering and product teams"
      testimonials={testimonials}
    />
  </div>

  <FAQ
    title="Frequently asked questions"
    subtitle="Everything you need to know before you get started."
    faqs={faqs}
  />

  <div class="section-inverted">
    <CTA
      title="Ready to transform how your team works?"
      description="Join over 120,000 teams already using Nebula to ship faster, collaborate better, and grow smarter."
      cta={{ href: "/signup", label: "Get Started Free" }}
    />
  </div>
</BaseLayout>
