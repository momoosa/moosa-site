---
interface Props {
  title?: string;
  subtitle?: string;
  email?: string;
  phone?: string;
  address?: string;
}

const {
  title = "Get in Touch",
  subtitle,
  email,
  phone,
  address,
} = Astro.props;

const hasContactInfo = email || phone || address;
---

<section class="py-16 md:py-24">
  <div class="container max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left column: info -->
      <div>
        <h2 class="text-3xl font-bold leading-tight md:text-4xl">
          {title}
        </h2>
        {subtitle && (
          <p class="mt-4 text-muted-foreground text-lg leading-relaxed">
            {subtitle}
          </p>
        )}

        {hasContactInfo && (
          <ul class="mt-8 space-y-5" aria-label="Contact information">
            {email && (
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-md border bg-muted"
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-muted-foreground"
                  >
                    <rect width="20" height="16" x="2" y="4" rx="2" />
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-0.5">Email</p>
                  <a
                    href={`mailto:${email}`}
                    class="text-sm text-foreground hover:text-primary transition-colors"
                  >
                    {email}
                  </a>
                </div>
              </li>
            )}

            {phone && (
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-md border bg-muted"
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-muted-foreground"
                  >
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.58 5.08 2 2 0 0 1 3.54 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 5.67 5.67l1.06-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.28 18z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-0.5">Phone</p>
                  <a
                    href={`tel:${phone}`}
                    class="text-sm text-foreground hover:text-primary transition-colors"
                  >
                    {phone}
                  </a>
                </div>
              </li>
            )}

            {address && (
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-md border bg-muted"
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-muted-foreground"
                  >
                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-0.5">Address</p>
                  <address class="text-sm text-foreground not-italic whitespace-pre-line">
                    {address}
                  </address>
                </div>
              </li>
            )}
          </ul>
        )}
      </div>

      <!-- Right column: form -->
      <div class="rounded-lg border bg-card p-6 md:p-8">
        <form action="#" method="POST" novalidate>
          <div class="space-y-5">

            <!-- Name -->
            <div class="space-y-1.5">
              <label
                for="contact-name"
                class="text-sm font-medium leading-none"
              >
                Name <span class="text-destructive" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-name"
                type="text"
                name="name"
                required
                autocomplete="name"
                placeholder="Jane Smith"
                class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
              />
            </div>

            <!-- Email -->
            <div class="space-y-1.5">
              <label
                for="contact-email"
                class="text-sm font-medium leading-none"
              >
                Email <span class="text-destructive" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="jane@example.com"
                class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
              />
            </div>

            <!-- Subject -->
            <div class="space-y-1.5">
              <label
                for="contact-subject"
                class="text-sm font-medium leading-none"
              >
                Subject
              </label>
              <input
                id="contact-subject"
                type="text"
                name="subject"
                autocomplete="off"
                placeholder="How can we help?"
                class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
              />
            </div>

            <!-- Message -->
            <div class="space-y-1.5">
              <label
                for="contact-message"
                class="text-sm font-medium leading-none"
              >
                Message <span class="text-destructive" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="5"
                placeholder="Tell us more about your project..."
                class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 resize-y min-h-[120px]"
              ></textarea>
            </div>

            <!-- Required field note -->
            <p class="text-xs text-muted-foreground">
              <span class="text-destructive" aria-hidden="true">*</span> Required fields
            </p>

            <!-- Submit -->
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8"
            >
              Send Message
            </button>

          </div>
        </form>
      </div>

    </div>
  </div>
</section>
