---
/**
 * Stats Section Component
 *
 * Displays a grid of key metrics with large value, label, and optional description.
 * Values are plain strings so callers can pass any format: "10K+", "99.9%", "$0", etc.
 *
 * @example
 * ```astro
 * <Stats
 *   title="Trusted by developers worldwide"
 *   subtitle="Numbers that speak for themselves"
 *   stats={[
 *     { value: "10K+", label: "Active users", description: "Across 90+ countries" },
 *     { value: "99.9%", label: "Uptime SLA", description: "Battle-tested infrastructure" },
 *     { value: "$0", label: "To get started", description: "Free forever on hobby tier" },
 *     { value: "4.9/5", label: "Average rating", description: "From 2,000+ reviews" },
 *   ]}
 * />
 * ```
 *
 * @customization
 * - Change grid columns by modifying grid class (line 40)
 * - Adjust value size with text-* classes on the value element
 * - Divider style controlled by border-* classes on each stat cell
 */

interface Stat {
  value: string;
  label: string;
  description?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  stats: Stat[];
}

const { title, subtitle, stats } = Astro.props;
---

<section class="py-16 md:py-24 px-6 border-y">
  <div class="container max-w-5xl mx-auto">
    {
      (title || subtitle) && (
        <div class="flex flex-col items-center space-y-4 text-center mb-14" data-animate>
          {title && (
            <h2 class="text-3xl font-bold leading-[1.1] sm:text-3xl md:text-5xl">
              {title}
            </h2>
          )}
          {subtitle && (
            <p class="max-w-[85%] leading-normal text-muted-foreground sm:text-lg sm:leading-7">
              {subtitle}
            </p>
          )}
        </div>
      )
    }

    <dl
      class="grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-border"
    >
      {
        stats.map((stat, index) => (
          <div class="flex flex-col items-center text-center px-6 py-8 md:py-0 first:pt-0 last:pb-0 md:first:pt-0 md:last:pb-0 md:first:pl-0 md:last:pr-0" data-animate data-delay={String(Math.min(index + 1, 5))}>
            <dd class="text-4xl font-bold tracking-tight text-foreground">
              {stat.value}
            </dd>
            <dt class="mt-2 text-sm font-semibold text-foreground">
              {stat.label}
            </dt>
            {stat.description && (
              <p class="mt-1 text-sm text-muted-foreground leading-snug">
                {stat.description}
              </p>
            )}
          </div>
        ))
      }
    </dl>
  </div>
</section>
