---
/**
 * Team Section Component
 *
 * Displays a grid of team member cards with avatars, names, roles, bios,
 * and optional social links (GitHub, LinkedIn, Twitter/X).
 *
 * @example
 * ```astro
 * <Team
 *   title="Meet Our Team"
 *   subtitle="The people building AstroDeck"
 *   members={[
 *     {
 *       name: "Jane Smith",
 *       role: "Co-Founder & CEO",
 *       bio: "Passionate about developer experience and open source.",
 *       social: {
 *         github: "https://github.com/janesmith",
 *         linkedin: "https://linkedin.com/in/janesmith",
 *         twitter: "https://twitter.com/janesmith"
 *       }
 *     }
 *   ]}
 * />
 * ```
 *
 * @customization
 * - Change grid columns by modifying grid class (line ~80)
 * - Adjust card hover effect via transition/scale/shadow classes
 * - Add new social icons to socialIcons object
 */

interface SocialLinks {
  github?: string;
  linkedin?: string;
  twitter?: string;
}

interface TeamMember {
  name: string;
  role: string;
  bio?: string;
  image?: string;
  social?: SocialLinks;
}

interface Props {
  title?: string;
  subtitle?: string;
  members: TeamMember[];
}

const { title = "Meet Our Team", subtitle, members } = Astro.props;

function getInitials(name: string): string {
  return name
    .split(" ")
    .map((n) => n[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
}

const socialIcons = {
  github: {
    label: "GitHub",
    path: "M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z",
  },
  linkedin: {
    label: "LinkedIn",
    path: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 6a2 2 0 1 1 0-4 2 2 0 0 1 0 4z",
  },
  twitter: {
    label: "X (Twitter)",
    path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  },
};
---

<section class="py-16 md:py-24 px-6">
  <div class="container max-w-6xl mx-auto">
    <div class="flex flex-col items-center space-y-4 text-center mb-12">
      <h2 class="text-3xl font-bold leading-[1.1] sm:text-3xl md:text-5xl">
        {title}
      </h2>
      {
        subtitle && (
          <p class="max-w-[85%] leading-normal text-muted-foreground sm:text-lg sm:leading-7">
            {subtitle}
          </p>
        )
      }
    </div>

    <div
      class:list={[
        "grid gap-6 sm:grid-cols-2 lg:grid-cols-3",
        members.length > 3 && "xl:grid-cols-4",
        members.length <= 3 && "max-w-4xl mx-auto",
      ]}
    >
      {
        members.map((member) => (
          <div class="group flex flex-col items-center text-center rounded-xl border bg-card p-6 transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5">
            <div class="mb-4">
              {member.image ? (
                <img
                  src={member.image}
                  alt={member.name}
                  width="80"
                  height="80"
                  class="h-20 w-20 rounded-full object-cover ring-2 ring-border"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="h-20 w-20 rounded-full bg-muted flex items-center justify-center ring-2 ring-border">
                  <span class="text-xl font-semibold text-muted-foreground select-none">
                    {getInitials(member.name)}
                  </span>
                </div>
              )}
            </div>

            <p class="font-semibold text-base leading-tight">{member.name}</p>
            <p class="text-sm text-muted-foreground mt-1">{member.role}</p>

            {member.bio && (
              <p class="text-sm text-muted-foreground mt-3 leading-relaxed">
                {member.bio}
              </p>
            )}

            {member.social &&
              Object.values(member.social).some(Boolean) && (
                <div class="flex items-center gap-3 mt-4 pt-4 border-t border-border w-full justify-center">
                  {member.social.github && (
                    <a
                      href={member.social.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${member.name} on ${socialIcons.github.label}`}
                      class="text-muted-foreground hover:text-foreground transition-colors duration-150"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="h-4 w-4"
                        aria-hidden="true"
                      >
                        <path d={socialIcons.github.path} />
                      </svg>
                    </a>
                  )}
                  {member.social.linkedin && (
                    <a
                      href={member.social.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${member.name} on ${socialIcons.linkedin.label}`}
                      class="text-muted-foreground hover:text-foreground transition-colors duration-150"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="h-4 w-4"
                        aria-hidden="true"
                      >
                        <path d={socialIcons.linkedin.path} />
                      </svg>
                    </a>
                  )}
                  {member.social.twitter && (
                    <a
                      href={member.social.twitter}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${member.name} on ${socialIcons.twitter.label}`}
                      class="text-muted-foreground hover:text-foreground transition-colors duration-150"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="h-4 w-4"
                        aria-hidden="true"
                      >
                        <path d={socialIcons.twitter.path} />
                      </svg>
                    </a>
                  )}
                </div>
              )}
          </div>
        ))
      }
    </div>
  </div>
</section>
