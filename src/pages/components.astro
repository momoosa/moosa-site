---
import FullWidthLayout from "@/layouts/FullWidthLayout.astro";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  DialogDemo,
  AccordionDemo,
  TabsDemo,
  TooltipDemo,
  SelectDemo,
  DropdownMenuDemo,
} from "@/components/demos/ComponentDemos";

const components = [
  { id: "button", label: "Button" },
  { id: "badge", label: "Badge" },
  { id: "card", label: "Card" },
  { id: "input", label: "Input & Label" },
  { id: "dialog", label: "Dialog" },
  { id: "accordion", label: "Accordion" },
  { id: "tabs", label: "Tabs" },
  { id: "tooltip", label: "Tooltip" },
  { id: "select", label: "Select" },
  { id: "dropdown", label: "Dropdown Menu" },
];

const codeSnippets: Record<string, string> = {
  button: `---
import { Button } from "@/components/ui/button";
---

<Button client:load>Default</Button>
<Button client:load variant="secondary">Secondary</Button>
<Button client:load variant="outline">Outline</Button>
<Button client:load variant="ghost">Ghost</Button>
<Button client:load variant="destructive">Destructive</Button>
<Button client:load variant="link">Link</Button>
<Button client:load size="sm">Small</Button>
<Button client:load size="lg">Large</Button>`,

  badge: `---
import { Badge } from "@/components/ui/badge";
---

<Badge client:load>Default</Badge>
<Badge client:load variant="secondary">Secondary</Badge>
<Badge client:load variant="outline">Outline</Badge>
<Badge client:load variant="destructive">Destructive</Badge>`,

  card: `---
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
---

<Card client:load>
  <CardHeader>
    <CardTitle>Card Title</CardTitle>
    <CardDescription>Card description goes here.</CardDescription>
  </CardHeader>
  <CardContent>
    <p>Card content and details.</p>
  </CardContent>
  <CardFooter>
    <Button>Action</Button>
  </CardFooter>
</Card>`,

  input: `---
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
---

<div class="space-y-2">
  <Label htmlFor="email">Email</Label>
  <Input type="email" id="email" placeholder="you@example.com" />
</div>`,

  dialog: `---
import { Dialog, DialogTrigger, DialogContent, DialogHeader, DialogTitle, DialogDescription } from "@/components/ui/dialog";
import { Button } from "@/components/ui/button";
---

<Dialog client:load>
  <DialogTrigger asChild>
    <Button>Open Dialog</Button>
  </DialogTrigger>
  <DialogContent>
    <DialogHeader>
      <DialogTitle>Dialog Title</DialogTitle>
      <DialogDescription>This is a dialog description.</DialogDescription>
    </DialogHeader>
    <p>Dialog body content goes here.</p>
  </DialogContent>
</Dialog>`,

  accordion: `---
import { Accordion, AccordionItem, AccordionTrigger, AccordionContent } from "@/components/ui/accordion";
---

<Accordion type="single" collapsible client:load>
  <AccordionItem value="item-1">
    <AccordionTrigger>Section One</AccordionTrigger>
    <AccordionContent>Content for section one.</AccordionContent>
  </AccordionItem>
  <AccordionItem value="item-2">
    <AccordionTrigger>Section Two</AccordionTrigger>
    <AccordionContent>Content for section two.</AccordionContent>
  </AccordionItem>
</Accordion>`,

  tabs: `---
import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/ui/tabs";
---

<Tabs defaultValue="tab1" client:load>
  <TabsList>
    <TabsTrigger value="tab1">Tab 1</TabsTrigger>
    <TabsTrigger value="tab2">Tab 2</TabsTrigger>
    <TabsTrigger value="tab3">Tab 3</TabsTrigger>
  </TabsList>
  <TabsContent value="tab1">First tab content.</TabsContent>
  <TabsContent value="tab2">Second tab content.</TabsContent>
  <TabsContent value="tab3">Third tab content.</TabsContent>
</Tabs>`,

  tooltip: `---
import { Tooltip, TooltipTrigger, TooltipContent, TooltipProvider } from "@/components/ui/tooltip";
import { Button } from "@/components/ui/button";
---

<TooltipProvider client:load>
  <Tooltip>
    <TooltipTrigger asChild>
      <Button variant="outline">Hover me</Button>
    </TooltipTrigger>
    <TooltipContent>
      <p>Tooltip text</p>
    </TooltipContent>
  </Tooltip>
</TooltipProvider>`,

  select: `---
import { Select, SelectTrigger, SelectValue, SelectContent, SelectItem } from "@/components/ui/select";
---

<Select client:load>
  <SelectTrigger className="w-[180px]">
    <SelectValue placeholder="Select option" />
  </SelectTrigger>
  <SelectContent>
    <SelectItem value="option1">Option 1</SelectItem>
    <SelectItem value="option2">Option 2</SelectItem>
    <SelectItem value="option3">Option 3</SelectItem>
  </SelectContent>
</Select>`,

  dropdown: `---
import { DropdownMenu, DropdownMenuTrigger, DropdownMenuContent, DropdownMenuItem, DropdownMenuLabel, DropdownMenuSeparator } from "@/components/ui/dropdown-menu";
import { Button } from "@/components/ui/button";
---

<DropdownMenu client:load>
  <DropdownMenuTrigger asChild>
    <Button variant="outline">Open Menu</Button>
  </DropdownMenuTrigger>
  <DropdownMenuContent>
    <DropdownMenuLabel>Actions</DropdownMenuLabel>
    <DropdownMenuSeparator />
    <DropdownMenuItem>Edit</DropdownMenuItem>
    <DropdownMenuItem>Duplicate</DropdownMenuItem>
    <DropdownMenuItem>Delete</DropdownMenuItem>
  </DropdownMenuContent>
</DropdownMenu>`,
};
---

<FullWidthLayout
  title="Components"
  description="Browse all AstroDeck UI components — buttons, cards, dialogs, tabs, and more. Built with shadcn/ui, Radix UI, and Tailwind CSS."
>
  <!-- Header -->
  <div class="py-16 px-6 md:px-12">
    <h1 class="text-4xl font-bold tracking-tight md:text-5xl mb-4">
      Component Library
    </h1>
    <p class="text-lg text-muted-foreground max-w-3xl">
      11 UI components built with <a href="https://ui.shadcn.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-foreground">shadcn/ui</a>, Radix UI primitives, and Tailwind CSS. Fully accessible, dark mode ready, and customizable.
    </p>
  </div>

  <!-- Mobile Sub-Navigation -->
  <div class="sticky top-14 z-30 lg:hidden border-b border-t bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 px-6 md:px-12">
    <button
      id="mobile-subnav-toggle"
      class="flex items-center justify-between w-full py-3 text-sm"
      aria-expanded="false"
      aria-controls="mobile-subnav-menu"
    >
      <span class="flex items-center gap-2 text-muted-foreground">
        <span>On this page:</span>
        <span id="mobile-subnav-current" class="font-medium text-foreground">Button</span>
      </span>
      <svg id="mobile-subnav-chevron" class="h-4 w-4 text-muted-foreground transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    <nav id="mobile-subnav-menu" class="hidden pb-3 space-y-1" aria-label="Component navigation">
      {components.map((c) => (
        <a
          href={`#${c.id}`}
          data-section={c.id}
          class="nav-link block px-3 py-2 text-sm rounded-md transition-colors"
        >
          {c.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Main Content with Sidebar -->
  <div class="lg:flex lg:gap-10 py-12 px-6 md:px-12">
    <!-- Sticky Sidebar Navigation (Desktop) -->
    <aside class="hidden lg:block lg:w-48 lg:shrink-0">
      <div class="sticky top-20">
        <nav id="components-nav" class="space-y-1" aria-label="Component navigation">
          <p class="text-sm font-semibold mb-4 text-muted-foreground" aria-hidden="true">Components</p>
          {components.map((c) => (
            <a
              href={`#${c.id}`}
              data-section={c.id}
              class="nav-link block px-3 py-2 text-sm rounded-md transition-colors"
            >
              {c.label}
            </a>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Component Content -->
    <main class="flex-1 min-w-0 space-y-16">

      <!-- Button -->
      <section id="button" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Button</h2>
          <p class="text-muted-foreground mt-1">6 variants, 4 sizes. Supports <code class="text-sm bg-muted px-1.5 py-0.5 rounded">asChild</code> for custom elements.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">All Variants</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="button">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-button">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.button}</code></pre>
          </div>
          <div class="border-t pt-6 space-y-4">
            <div class="flex flex-wrap gap-3 items-center">
              <Button client:load>Default</Button>
              <Button client:load variant="secondary">Secondary</Button>
              <Button client:load variant="outline">Outline</Button>
              <Button client:load variant="ghost">Ghost</Button>
              <Button client:load variant="destructive">Destructive</Button>
              <Button client:load variant="link">Link</Button>
            </div>
            <div class="flex flex-wrap gap-3 items-center">
              <Button client:load size="sm">Small</Button>
              <Button client:load size="default">Default</Button>
              <Button client:load size="lg">Large</Button>
              <Button client:load size="icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </Button>
            </div>
          </div>
        </div>
      </section>

      <!-- Badge -->
      <section id="badge" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Badge</h2>
          <p class="text-muted-foreground mt-1">Pill-shaped labels for status, tags, or categories.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">All Variants</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="badge">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-badge">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.badge}</code></pre>
          </div>
          <div class="border-t pt-6 flex flex-wrap gap-3 items-center">
            <Badge client:load>Default</Badge>
            <Badge client:load variant="secondary">Secondary</Badge>
            <Badge client:load variant="outline">Outline</Badge>
            <Badge client:load variant="destructive">Destructive</Badge>
          </div>
        </div>
      </section>

      <!-- Card -->
      <section id="card" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Card</h2>
          <p class="text-muted-foreground mt-1">Compound component with Header, Title, Description, Content, and Footer.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Card with Actions</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="card">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-card">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.card}</code></pre>
          </div>
          <div class="border-t pt-6">
            <div class="max-w-sm">
              <Card client:load>
                <CardHeader>
                  <CardTitle>Project Settings</CardTitle>
                  <CardDescription>Manage your project configuration and preferences.</CardDescription>
                </CardHeader>
                <CardContent>
                  <p class="text-sm text-muted-foreground">Update your project name, description, and visibility settings.</p>
                </CardContent>
                <CardFooter className="flex justify-between">
                  <Button variant="outline">Cancel</Button>
                  <Button>Save</Button>
                </CardFooter>
              </Card>
            </div>
          </div>
        </div>
      </section>

      <!-- Input & Label -->
      <section id="input" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Input & Label</h2>
          <p class="text-muted-foreground mt-1">Form input field with associated label. Supports all HTML input types.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Form Fields</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="input">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-input">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.input}</code></pre>
          </div>
          <div class="border-t pt-6 max-w-sm space-y-4">
            <div class="space-y-2">
              <Label client:load htmlFor="demo-email">Email</Label>
              <Input client:load type="email" id="demo-email" placeholder="you@example.com" />
            </div>
            <div class="space-y-2">
              <Label client:load htmlFor="demo-pw">Password</Label>
              <Input client:load type="password" id="demo-pw" placeholder="Enter password" />
            </div>
            <div class="space-y-2">
              <Label client:load htmlFor="demo-dis">Disabled</Label>
              <Input client:load id="demo-dis" placeholder="Can't type here" disabled />
            </div>
          </div>
        </div>
      </section>

      <!-- Dialog -->
      <section id="dialog" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Dialog</h2>
          <p class="text-muted-foreground mt-1">Modal overlay with backdrop blur. Traps focus and closes on escape.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Modal Dialog</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="dialog">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-dialog">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.dialog}</code></pre>
          </div>
          <div class="border-t pt-6">
            <DialogDemo client:load />
          </div>
        </div>
      </section>

      <!-- Accordion -->
      <section id="accordion" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Accordion</h2>
          <p class="text-muted-foreground mt-1">Collapsible content with smooth height animation. Single or multiple mode.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Collapsible Accordion</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="accordion">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-accordion">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.accordion}</code></pre>
          </div>
          <div class="border-t pt-6">
            <AccordionDemo client:load />
          </div>
        </div>
      </section>

      <!-- Tabs -->
      <section id="tabs" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Tabs</h2>
          <p class="text-muted-foreground mt-1">Pill-style tab navigation with keyboard support.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Tab Navigation</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="tabs">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-tabs">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.tabs}</code></pre>
          </div>
          <div class="border-t pt-6">
            <TabsDemo client:load />
          </div>
        </div>
      </section>

      <!-- Tooltip -->
      <section id="tooltip" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Tooltip</h2>
          <p class="text-muted-foreground mt-1">Small popup on hover with positioning and delay support.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Hover Tooltip</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="tooltip">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-tooltip">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.tooltip}</code></pre>
          </div>
          <div class="border-t pt-6">
            <TooltipDemo client:load />
          </div>
        </div>
      </section>

      <!-- Select -->
      <section id="select" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Select</h2>
          <p class="text-muted-foreground mt-1">Styled dropdown select with groups, labels, and check icon.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Select Dropdown</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="select">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-select">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.select}</code></pre>
          </div>
          <div class="border-t pt-6">
            <SelectDemo client:load />
          </div>
        </div>
      </section>

      <!-- Dropdown Menu -->
      <section id="dropdown" class="scroll-mt-20">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Dropdown Menu</h2>
          <p class="text-muted-foreground mt-1">Positioned menu with items, labels, separators, and keyboard navigation.</p>
        </div>
        <div class="border rounded-lg p-8 bg-card">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold">Action Menu</h3>
            <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="dropdown">Copy Code</button>
          </div>
          <div class="code-block hidden" id="code-dropdown">
            <pre class="mb-6 p-4 bg-muted rounded-md overflow-x-auto text-sm"><code>{codeSnippets.dropdown}</code></pre>
          </div>
          <div class="border-t pt-6">
            <DropdownMenuDemo client:load />
          </div>
        </div>
      </section>

    </main>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Copy code toggle
      document.querySelectorAll('.copy-btn').forEach(button => {
        button.addEventListener('click', async () => {
          const codeId = `code-${(button as HTMLElement).dataset.code}`;
          const codeBlock = document.getElementById(codeId);
          if (!codeBlock) return;

          const isHidden = codeBlock.classList.contains('hidden');
          if (isHidden) {
            codeBlock.classList.remove('hidden');
            const code = codeBlock.querySelector('code')?.textContent || '';
            try {
              await navigator.clipboard.writeText(code);
              button.textContent = 'Copied!';
              button.classList.add('bg-primary', 'text-primary-foreground');
              setTimeout(() => {
                button.textContent = 'Hide Code';
                button.classList.remove('bg-primary', 'text-primary-foreground');
              }, 1500);
            } catch {
              button.textContent = 'Hide Code';
            }
          } else {
            codeBlock.classList.add('hidden');
            button.textContent = 'Copy Code';
          }
        });
      });

      // Mobile subnav toggle
      const mobileToggle = document.getElementById('mobile-subnav-toggle');
      const mobileMenu = document.getElementById('mobile-subnav-menu');
      const mobileChevron = document.getElementById('mobile-subnav-chevron');
      const mobileCurrent = document.getElementById('mobile-subnav-current');

      mobileToggle?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden');
        mobileChevron?.classList.toggle('rotate-180');
        mobileToggle.setAttribute('aria-expanded', String(isOpen));
      });

      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileChevron?.classList.remove('rotate-180');
          mobileToggle?.setAttribute('aria-expanded', 'false');
        });
      });

      // Sidebar navigation highlighting
      const navLinks = document.querySelectorAll('.nav-link');
      const pageSections = document.querySelectorAll('section[id]');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            navLinks.forEach(link => {
              link.classList.remove('bg-foreground', 'text-background');
            });
            document.querySelectorAll(`[data-section="${id}"]`).forEach(link => {
              link.classList.add('bg-foreground', 'text-background');
            });
            if (mobileCurrent) {
              const activeLink = document.querySelector(`aside [data-section="${id}"]`);
              mobileCurrent.textContent = activeLink?.textContent?.trim() || '';
            }
          }
        });
      }, { root: null, rootMargin: '-100px 0px -66%', threshold: 0 });

      pageSections.forEach(section => observer.observe(section));
    });
  </script>
</FullWidthLayout>
