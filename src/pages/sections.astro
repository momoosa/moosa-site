---

<FullWidthLayout title="Sections" description="Explore reusable components and sections for your Astro.js project">
  <style>
    html {
      scroll-behavior: smooth;
    }
    .code-block {
      display: none;
      margin-top: 1rem;
      background: hsl(var(--muted));
      border-radius: 0.5rem;
      overflow: hidden;
    }
    .code-block.show {
      display: block;
    }
    .code-block pre {
      padding: 1rem;
      overflow-x: auto;
      font-size: 0.75rem;
      line-height: 1.5;
    }
    .code-block code {
      font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
    }
    .nav-link:not(.bg-foreground):hover {
      background-color: var(--color-muted);
    }
    .nav-link.bg-foreground:hover {
      opacity: 0.9;
    }
  </style>
  <div class="min-h-screen">
    <!-- Header -->
    <div class="py-16 px-6 md:px-12">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl mb-4">
        Section Library
      </h1>
      <p class="text-lg text-muted-foreground max-w-3xl">
        Copy-paste ready components for your landing page. Each section is fully customizable and built with TypeScript, Tailwind CSS, and shadcn/ui.
      </p>
    </div>

    <!-- Mobile Sub-Navigation -->
    <div class="sticky top-14 z-30 lg:hidden border-b border-t bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 px-6 md:px-12">
      <button
          id="mobile-subnav-toggle"
          class="flex items-center justify-between w-full py-3 text-sm"
          aria-expanded="false"
          aria-controls="mobile-subnav-menu"
        >
          <span class="flex items-center gap-2 text-muted-foreground">
            <span>On this page:</span>
            <span id="mobile-subnav-current" class="font-medium text-foreground">Heroes</span>
          </span>
          <svg id="mobile-subnav-chevron" class="h-4 w-4 text-muted-foreground transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <nav id="mobile-subnav-menu" class="hidden pb-3 space-y-1" aria-label="Section navigation">
          {sections.map((section) => (
            <a
              href={`#${section.id}`}
              data-section={section.id}
              class="nav-link flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors"
            >
              <span>{section.label}</span>
              <span class="text-xs text-muted-foreground">({section.count})</span>
            </a>
          ))}
      </nav>
    </div>

    <!-- Main Content with Sidebar -->
    <div class="lg:flex lg:gap-10 py-12 px-6 md:px-12">
      <!-- Sticky Sidebar Navigation (Desktop) -->
      <aside class="hidden lg:block lg:w-48 lg:shrink-0">
        <div class="sticky top-20">
          <nav id="sections-nav" class="space-y-1" aria-label="Section navigation">
            <p class="text-sm font-semibold mb-4 text-muted-foreground" aria-hidden="true">Sections</p>
            {sections.map((section) => (
              <a
                href={`#${section.id}`}
                data-section={section.id}
                class="nav-link flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors"
              >
                <span>{section.label}</span>
                <span class="text-xs text-muted-foreground">({section.count})</span>
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <!-- Sections Content -->
      <main class="flex-1 min-w-0 space-y-16">
          <!-- Heroes -->
          <section id="heroes" class="scroll-mt-20">
            <div class="mb-8">
              <h2 class="text-3xl font-bold mb-2">Hero Sections</h2>
              <p class="text-muted-foreground">Eye-catching hero sections to make a strong first impression.</p>
            </div>

            <div class="space-y-12">
              <!-- Hero 1: Centered with Badge -->
              <div class="border rounded-lg p-8 bg-card">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="font-semibold">Centered with Badge</h3>
                  <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="heroCentered">
                    Copy Code
                  </button>
                </div>
                <div class="code-block" id="code-heroCentered">
                  <pre><code>{codeSnippets.heroCentered}</code></pre>
                </div>
                <div class="border-t pt-6">
                  <div class="min-h-[400px] flex items-center">
                    <div class="w-full flex flex-col items-center gap-6 text-center">
                      <div class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-medium">
                        <span class="bg-foreground text-background px-2 py-0.5 rounded-md font-semibold text-xs">NEW</span>
                        <span>Introducing our latest feature</span>
                      </div>
                      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-6xl max-w-3xl">Build amazing products faster</h1>
                      <p class="max-w-[600px] text-lg text-muted-foreground">Start with our pre-built components and focus on what matters. Ship faster, iterate quicker.</p>
                      <div class="flex flex-col sm:flex-row gap-4 mt-4">
                        <a href="#" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-12 px-8">Get Started</a>
                        <a href="#" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-12 px-8">Learn More</a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Hero 2: Left Aligned with Image -->
              <div class="border rounded-lg p-8 bg-card">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="font-semibold">Left Aligned with Visual</h3>
                  <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="heroLeftAligned">
                    Copy Code
                  </button>
                </div>
                <div class="code-block" id="code-heroLeftAligned">
                  <pre><code>{codeSnippets.heroLeftAligned}</code></pre>
                </div>
                <div class="border-t pt-6">
                  <div class="min-h-[400px] grid lg:grid-cols-2 gap-12 items-center">
                    <div class="space-y-6">
                      <div class="inline-block px-3 py-1 bg-primary/10 text-primary text-sm font-medium rounded-full">🚀 Launch Week</div>
                      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl">Ship your SaaS in days, not months</h1>
                      <p class="text-lg text-muted-foreground">Everything you need to build a modern landing page. TypeScript, Tailwind, and shadcn/ui included.</p>
                      <div class="flex gap-4">
                        <a href="#" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8">Start Building</a>
                        <a href="#" class="inline-flex items-center justify-center rounded-md text-sm font-medium border h-11 px-8">View Demo</a>
                      </div>
                    </div>
                    <div class="bg-muted rounded-lg aspect-square flex items-center justify-center">
                      <p class="text-muted-foreground">Image Placeholder</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Hero 3: Minimal with Stats -->
              <div class="border rounded-lg p-8 bg-card">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="font-semibold">Minimal with Stats</h3>
                  <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="heroMinimal">
                    Copy Code
                  </button>
                </div>
                <div class="code-block" id="code-heroMinimal">
                  <pre><code>{codeSnippets.heroMinimal}</code></pre>
                </div>
                <div class="border-t pt-6">
                  <div class="min-h-[400px] flex items-center">
                    <div class="w-full space-y-8">
                      <div class="max-w-3xl mx-auto text-center space-y-6">
                        <h1 class="text-5xl font-bold leading-tight tracking-tight md:text-6xl">The complete toolkit for modern development</h1>
                        <p class="text-xl text-muted-foreground">Join thousands of developers building with AstroDeck</p>
                      </div>
                      <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto pt-8">
                        <div class="text-center">
                          <div class="text-3xl font-bold">50K+</div>
                          <div class="text-sm text-muted-foreground mt-1">Downloads</div>
                        </div>
                        <div class="text-center">
                          <div class="text-3xl font-bold">1.2K+</div>
                          <div class="text-sm text-muted-foreground mt-1">GitHub Stars</div>
                        </div>
                        <div class="text-center">
                          <div class="text-3xl font-bold">99%</div>
                          <div class="text-sm text-muted-foreground mt-1">Satisfaction</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- CTAs -->
          <section id="ctas" class="scroll-mt-20">
            <div class="mb-8">
              <h2 class="text-3xl font-bold mb-2">Call to Action</h2>
              <p class="text-muted-foreground">Convert visitors with compelling CTAs.</p>
            </div>

            <div class="space-y-12">
              <!-- CTA 1: Simple Centered -->
              <div class="border rounded-lg p-8 bg-card">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="font-semibold">Simple Centered</h3>
                  <button class="copy-btn text-sm px-3 py-1 border rounded-md hover:bg-muted transition-colors" data-code="ctaSimple">
                    Copy Code
                  </button>
