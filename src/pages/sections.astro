  <script>
    // Copy code functionality
    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');
      
      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const codeId = button.getAttribute('data-code');
          const codeBlock = document.getElementById(`code-${codeId}`);
          
          // Toggle code visibility
          codeBlock?.classList.toggle('show');
          
          if (codeBlock?.classList.contains('show')) {
            // Copy to clipboard
            const codeText = codeBlock.querySelector('code')?.textContent || '';
            
            try {
              await navigator.clipboard.writeText(codeText);
              const originalText = button.textContent;
              button.textContent = 'Copied!';
              button.classList.add('bg-primary', 'text-primary-foreground');
              
              setTimeout(() => {
                button.textContent = 'Hide Code';
                button.classList.remove('bg-primary', 'text-primary-foreground');
              }, 1500);
            } catch (err) {
              console.error('Failed to copy:', err);
            }
          } else {
            button.textContent = 'Copy Code';
          }
        });
      });

      // Mobile subnav toggle
      const mobileToggle = document.getElementById('mobile-subnav-toggle');
      const mobileMenu = document.getElementById('mobile-subnav-menu');
      const mobileChevron = document.getElementById('mobile-subnav-chevron');
      const mobileCurrent = document.getElementById('mobile-subnav-current');

      mobileToggle?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden');
        mobileChevron?.classList.toggle('rotate-180');
        mobileToggle.setAttribute('aria-expanded', String(isOpen));
      });

      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileChevron?.classList.remove('rotate-180');
          mobileToggle?.setAttribute('aria-expanded', 'false');
        });
      });

      // Sidebar navigation highlighting
      const navLinks = document.querySelectorAll('.nav-link');
      const pageSections = document.querySelectorAll('section[id]');

      const observerOptions = {
        root: null,
        rootMargin: '-100px 0px -66%',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            navLinks.forEach(link => {
              link.classList.remove('bg-foreground', 'text-background');
              const countSpan = link.querySelector('.text-xs');
              if (countSpan) {
                countSpan.classList.remove('text-muted-foreground/60');
                countSpan.classList.add('text-muted-foreground');
              }
            });
            const activeLinks = document.querySelectorAll(`[data-section="${id}"]`);
            activeLinks.forEach(link => {
              link.classList.add('bg-foreground', 'text-background');
              const countSpan = link.querySelector('.text-xs');
              if (countSpan) {
                countSpan.classList.remove('text-muted-foreground');
                countSpan.classList.add('text-muted-foreground/60');
              }
            });
            // Update mobile current label
            if (mobileCurrent) {
              const activeLink = document.querySelector(`aside [data-section="${id}"]`);
              if (activeLink) {
                const labelSpan = activeLink.querySelector('span');
                mobileCurrent.textContent = labelSpan?.textContent?.trim() || '';
              }
            }
          }
        });
      }, observerOptions);

      pageSections.forEach(section => observer.observe(section));
    });
  </script>
