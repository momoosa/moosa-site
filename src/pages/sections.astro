---
import FullWidthLayout from "@/layouts/FullWidthLayout.astro";

const sections = [
  { id: "heroes", label: "Heroes", count: 3 },
  { id: "ctas", label: "CTAs", count: 3 },
  { id: "pricing", label: "Pricing", count: 4 },
  { id: "testimonials", label: "Testimonials", count: 3 },
  { id: "newsletters", label: "Newsletters", count: 3 },
  { id: "faq", label: "FAQ", count: 1 },
  { id: "stats", label: "Stats", count: 1 },
  { id: "team", label: "Team", count: 1 },
  { id: "comparison", label: "Comparison", count: 1 },
  { id: "contact", label: "Contact", count: 1 },
